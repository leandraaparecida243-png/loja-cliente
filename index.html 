</div>

<div class="cart-overlay" id="cart-overlay" onclick="if(event.target===this) toggleCart()">
    <div class="cart-modal">
        <div class="cart-header">
            <h2 style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:.08em;">SEU CARRINHO</h2>
            <button style="background:#222; border:none; color:#fff; width:30px; height:30px; border-radius:50%; cursor:pointer;" onclick="toggleCart()">✕</button>
        </div>
        <div class="cart-items" id="cart-items"></div>
        <div class="checkout-section">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px; font-weight:bold;">
                <span>Total</span>
                <span id="cart-total" style="color:var(--accent);font-family:'Bebas Neue',sans-serif;font-size:1.1rem;">R$ 0,00</span>
            </div>
            <div class="checkout-form">
                <input type="text" id="c-nome" placeholder="Nome Completo">
                <input type="tel" id="c-whatsapp" placeholder="WhatsApp com DDD">
                <input type="text" id="c-endereco" placeholder="Endereço de Entrega">
                <select id="c-pagamento">
                    <option value="PIX">💠 PIX</option>
                    <option value="Cartão">💳 Cartão de Crédito</option>
                    <option value="Dinheiro">💵 Dinheiro na Entrega</option>
                </select>
                <button class="finish-btn" onclick="finalizarCompra()">🚀 FINALIZAR NO WHATSAPP</button>
            </div>
        </div>
    </div>
</div>

