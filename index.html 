</div>

<div id="size-modal">
    <div class="size-box">
        <h3 style="font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:.08em;">ESCOLHA O TAMANHO</h3>
        <div class="size-options" id="size-options"></div>
