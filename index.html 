<script>
    // ── CONFIG ──
    const BIN_ID  = '6a187891ddf5aa59f770c17c';
    const API_KEY = '$2a$10$bD7LDT0NM41fX03433GmPOb4pfAWxTsOJm7Od2RVXg/mIdEKzRfmK';

    let produtos = [];
    let produtosFiltrados = [];
    let carrinho = [];
    let produtoSelecionado = null;
    let tamanhoSelecionado = null;

    // ── CARREGAR DADOS ──
    async function carregarDados() {
        const grid = document.getElementById('products-grid');
        grid.innerHTML = `<div class="loading-state"><div class="spinner-loja"></div><p>CARREGANDO PRODUTOS...</p></div>`;
        try {
            const rProds = await fetch(`https://api.jsonbin.io/v3/b/${BIN_ID}/latest`, {
                headers: { 'X-Master-Key': API_KEY }
            });
            if (!rProds.ok) throw new Error('Erro produtos');
            const dProds = await rProds.json();
            produtos = Array.isArray(dProds.record) ? dProds.record : [];
            produtos = produtos.filter(p => p.nome && p.nome.trim() !== '');
            renderizarProdutos(produtos);
        } catch(e) {
            console.error(e);
            grid.innerHTML = `
                <div class="erro-estado">
                    <p>⚠️ Não foi possível carregar os produtos.<br>Verifique sua conexão.</p>
                    <button onclick="carregarDados()">TENTAR NOVAMENTE</button>
                </div>`;
        }
    }

    // ── RESOLVER URL DA FOTO ──
    function getFotoUrl(p) {
        return p.foto || '';
    }

    // ── RENDERIZAR PRODUTOS ──
    function renderizarProdutos(lista) {
        produtosFiltrados = lista;
        const grid = document.getElementById('products-grid');
        if (lista.length === 0) {
            grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;color:var(--text-muted);padding:3rem 0;font-size:.82rem;">Nenhum produto encontrado.</p>';
            return;
        }
        grid.innerHTML = lista.map((p, idx) => {
            const foto = getFotoUrl(p);
            return `
            <div class="product-card">
                <img src="${foto}" class="product-img" alt="${p.nome}"
                    onerror="this.style.background='#0a0d11'; this.removeAttribute('src')">
                <div class="product-info">
                    <h3>${p.nome}</h3>
                    <div class="price">R$ ${parseFloat(p.preco).toFixed(2)}</div>
                </div>
                <button class="add-btn" onclick="abrirModalTamanho(${idx})">COMPRAR</button>
            </div>`;
        }).join('');
    }

    // ── FILTRO DE CATEGORIA ──
    function filterCategory(cat, btn) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        if (cat === 'todos') renderizarProdutos(produtos);
        else renderizarProdutos(produtos.filter(p => p.categoria && p.categoria.toLowerCase() === cat.toLowerCase()));
    }

    // ── MODAL TAMANHO ──
    function abrirModalTamanho(idx) {
        produtoSelecionado = produtosFiltrados[idx];
        if (!produtoSelecionado) return;
        const options = document.getElementById('size-options');
        let tamanhos = produtoSelecionado.tamanhos || ['P', 'M', 'G', 'GG'];
        if (typeof tamanhos === 'string') tamanhos = tamanhos.split(',').map(t => t.trim());
        if (!Array.isArray(tamanhos) || tamanhos.length === 0) tamanhos = ['ÚNICO'];
        options.innerHTML = tamanhos.map(t => `<div class="size-opt" onclick="selecionarTamanho('${t}', this)">${t}</div>`).join('');
        document.getElementById('size-modal').classList.add('aberto');
        tamanhoSelecionado = null;
    }

    function selecionarTamanho(tam, el) {
        document.querySelectorAll('.size-opt').forEach(opt => opt.classList.remove('active'));
        el.classList.add('active');
        tamanhoSelecionado = tam;
    }

    function fecharModalTamanho() { document.getElementById('size-modal').classList.remove('aberto'); }

    function confirmarTamanho() {
        if (!tamanhoSelecionado) { alert('Selecione um tamanho!'); return; }
        adicionarAoCarrinho(produtoSelecionado, tamanhoSelecionado);
        fecharModalTamanho();
        showToast();
    }

    // ── CARRINHO ──
    function adicionarAoCarrinho(prod, tam) {
        const item = carrinho.find(i => i.id == prod.id && i.tamanho === tam);
        if (item) item.quantidade++;
        else carrinho.push({ ...prod, tamanho: tam, quantidade: 1 });
        atualizarCarrinho();
    }

    function atualizarCarrinho() {
        const container = document.getElementById('cart-items');
        const count     = document.getElementById('cart-count');
        const total     = document.getElementById('cart-total');
        let soma = 0, itens = 0;

        container.innerHTML = carrinho.map((item, idx) => {
            soma  += item.preco * item.quantidade;
            itens += item.quantidade;
            const foto = getFotoUrl(item);
            return `
            <div class="cart-item">
                ${foto ? `<img src="${foto}" alt="${item.nome}">` : `<div style="width:50px;height:50px;background:#0a0d11;border-radius:8px;"></div>`}
                <div style="flex:1">
                    <h4 style="font-size:0.8rem">${item.nome}</h4>
                    <p style="color:var(--accent);font-size:0.8rem">R$ ${item.preco.toFixed(2)} · Tam: ${item.tamanho}</p>
                </div>
                <div style="display:flex;align-items:center;gap:8px">
                    <button onclick="mudarQtd(${idx}, -1)" style="background:#222;border:none;color:#fff;width:24px;height:24px;border-radius:4px;cursor:pointer;">-</button>
                    <span style="min-width:16px;text-align:center;">${item.quantidade}</span>
                    <button onclick="mudarQtd(${idx}, 1)" style="background:#222;border:none;color:#fff;width:24px;height:24px;border-radius:4px;cursor:pointer;">+</button>
                </div>
            </div>`;
        }).join('');

        if (carrinho.length === 0) {
            container.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:20px;font-size:.82rem;">Carrinho vazio</p>';
        }

        count.textContent = itens;
        total.textContent = `R$ ${soma.toFixed(2).replace('.', ',')}`;
    }

    function mudarQtd(idx, delta) {
        carrinho[idx].quantidade += delta;
        if (carrinho[idx].quantidade <= 0) carrinho.splice(idx, 1);
        atualizarCarrinho();
    }

    function toggleCart() { document.getElementById('cart-overlay').classList.toggle('active'); }

    // ── FINALIZAR COMPRA ──
    function finalizarCompra() {
        if (carrinho.length === 0) { alert('Carrinho vazio!'); return; }
        const nome      = document.getElementById('c-nome').value.trim();
        const whatsapp  = document.getElementById('c-whatsapp').value.trim();
        const endereco  = document.getElementById('c-endereco').value.trim();
        const pagamento = document.getElementById('c-pagamento').value;

        if (!nome || !whatsapp || !endereco) { alert('Preencha todos os campos!'); return; }

        const resumo = carrinho.map(i => `• ${i.quantidade}x ${i.nome} (Tam: ${i.tamanho})`).join('\n');
        const total  = document.getElementById('cart-total').textContent;

        const msg = `🛍 *NOVO PEDIDO - MDSURF*\n\n👤 *Cliente:* ${nome}\n📱 *WhatsApp:* ${whatsapp}\n📍 *Endereço:* ${endereco}\n💳 *Pagamento:* ${pagamento}\n\n📦 *Produtos:*\n${resumo}\n\n💰 *Total: ${total}*`;
        const fone = '5516981928132';
        window.open(`https://wa.me/${fone}?text=${encodeURIComponent(msg)}`, '_blank');
    }

    function showToast() {
        const t = document.getElementById('toast');
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    // ── INIT ──
    carregarDados();
</script>
</body>
</html>
