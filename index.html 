<style>
    #rodape {
        position: relative; z-index: 1;
        background: #0a0d11;
        border-top: 1px solid rgba(255,255,255,.06);
        padding: 2rem 1.2rem;
        text-align: center;
        margin-top: 1rem;
    }
    .rodape-logo {
        font-family: 'Bebas Neue', sans-serif;
