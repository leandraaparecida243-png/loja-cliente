<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MDSURF | STREETWEAR</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent:      #00d4ff;
            --accent2:     #ff6b35;
            --lime:        #c8ff00;
            --dark:        #070a0d;
            --card:        #0c0f14;
            --card2:       #0a0d11;
            --border:      rgba(0,212,255,.12);
            --border-soft: rgba(255,255,255,.06);
            --text-muted:  #555b68;
            --text-mid:    #8b929e;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            background: var(--dark);
            color: #e8eaf0;
            font-family: 'Barlow', sans-serif;
            overflow-x: hidden;
            line-height: 1.5;
        }

        body::before {
            content: ''; position: fixed; inset: 0;
            background:
                radial-gradient(ellipse 70% 50% at 5% 100%, rgba(200,255,0,.045) 0%, transparent 55%),
                radial-gradient(ellipse 50% 40% at 95% 0%, rgba(0,212,255,.04) 0%, transparent 50%);
            pointer-events: none; z-index: 0;
        }
        body::after {
            content: ''; position: fixed; inset: 0;
            background-image: repeating-linear-gradient(-45deg, transparent, transparent 30px, rgba(255,255,255,.011) 30px, rgba(255,255,255,.011) 31px);
            pointer-events: none; z-index: 0;
        }

        /* HEADER */
        header {
            position: sticky; top: 0; z-index: 100;
            padding: 14px 18px; display: flex; justify-content: space-between; align-items: center;
            background: rgba(7,10,13,.88); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border-soft);
        }
        .logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.75rem; letter-spacing: .1em; color: #fff; }
        .logo em { color: var(--accent); font-style: normal; }

        .cart-btn {
            position: relative; background: var(--card); border: 1.5px solid var(--border-soft);
            padding: .55rem 1rem; border-radius: 10px; cursor: pointer;
            display: flex; align-items: center; gap: .4rem; font-size: .82rem; font-weight: 600; color: var(--text-mid);
        }
        .cart-count {
            position: absolute; top: -6px; right: -6px; background: var(--lime); color: #000;
            font-size: .65rem; font-weight: 800; width: 19px; height: 19px;
            display: flex; align-items: center; justify-content: center; border-radius: 50%;
        }

        /* HERO */
        .hero { position: relative; z-index: 1; padding: 2.5rem 1.2rem 1.5rem; text-align: center; }
        .hero h2 { font-family: 'Bebas Neue', sans-serif; font-size: 3rem; letter-spacing: .05em; line-height: .95; color: #fff; }
        .hero h2 em { color: var(--accent); font-style: normal; }
        .hero p { color: var(--text-muted); font-size: .82rem; margin-top: 10px; }

        /* CATEGORIES */
        .categories { display: flex; gap: 8px; padding: 1rem 1.2rem; overflow-x: auto; scrollbar-width: none; position: relative; z-index: 1; }
        .cat-btn {
            padding: .55rem 1.1rem; background: var(--card2); border: 1.5px solid var(--border-soft);
            border-radius: 8px; white-space: nowrap; color: var(--text-muted); font-size: .75rem; font-weight: 700; cursor: pointer;
        }
        .cat-btn.active { background: var(--accent); color: #000; border-color: var(--accent); }

        /* PRODUCTS GRID */
        .products-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 0 1.2rem 7rem; position: relative; z-index: 1; }
        .product-card { background: var(--card); border: 1px solid var(--border-soft); border-radius: 16px; padding: 10px; position: relative; }
        .product-img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; margin-bottom: 10px; background: #0a0d11; }
        .product-info h3 { font-size: .82rem; font-weight: 600; color: #d8dae0; margin-bottom: 3px; }
        .product-info .price { color: var(--accent); font-weight: 800; font-size: .95rem; font-family: 'Bebas Neue', sans-serif; }
        .add-btn { width: 100%; margin-top: 10px; background: var(--lime); color: #000; border: none; padding: .65rem; border-radius: 8px; font-family: 'Bebas Neue', sans-serif; cursor: pointer; }

        /* LOADING SKELETON */
        .loading-state { grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 3rem 0; }
        .spinner-loja { width: 28px; height: 28px; border: 3px solid rgba(0,212,255,.2); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.9s linear infinite; }
        .loading-state p { color: var(--text-muted); font-size: .78rem; font-weight: 600; letter-spacing: .1em; }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* MODAL TAMANHO */
        #size-modal { position: fixed; inset: 0; background: rgba(0,0,0,.92); display: none; align-items: flex-end; justify-content: center; z-index: 9000; backdrop-filter: blur(12px); }
        #size-modal.aberto { display: flex; }
        .size-box { background: var(--card); padding: 2rem 1.4rem 2.5rem; border-radius: 22px 22px 0 0; width: 100%; max-width: 480px; border-top: 1px solid var(--border-soft); }
        .size-options { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 1.2rem 0; }
        .size-opt { padding: .75rem; border: 1.5px solid var(--border-soft); border-radius: 8px; cursor: pointer; font-weight: 700; text-align: center; color: var(--text-mid); }
        .size-opt.active { background: var(--lime); color: #000; border-color: var(--lime); }
        .size-confirm-btn { width: 100%; padding: .9rem; background: var(--accent); color: #000; border: none; border-radius: 10px; font-family: 'Bebas Neue', sans-serif; font-size: 1.15rem; cursor: pointer; }

        /* CARRINHO */
        .cart-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.82); backdrop-filter: blur(10px); z-index: 200; visibility: hidden; opacity: 0; transition: 0.3s; }
        .cart-overlay.active { visibility: visible; opacity: 1; }
        .cart-modal { position: fixed; bottom: 0; left: 0; right: 0; background: #090c10; border-top: 1px solid var(--border-soft); border-radius: 24px 24px 0 0; padding: 1.5rem 1.2rem 2rem; max-height: 90vh; overflow-y: auto; transform: translateY(100%); transition: 0.4s; }
        .cart-overlay.active .cart-modal { transform: translateY(0); }
        .cart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.4rem; }
        .cart-items { display: flex; flex-direction: column; gap: 10px; margin-bottom: 1.4rem; }
        .cart-item { display: flex; gap: 12px; align-items: center; background: var(--card2); padding: 10px; border-radius: 12px; }
        .cart-item img { width: 50px; height: 50px; border-radius: 8px; object-fit: cover; background: #0a0d11; }
        .checkout-form input, .checkout-form select { width: 100%; padding: 12px; background: #0d1117; border: 1px solid #222; border-radius: 8px; color: #fff; margin-bottom: 8px; font-family: inherit; }
        .finish-btn { width: 100%; padding: 1rem; background: #25d366; color: #fff; border: none; border-radius: 10px; font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; cursor: pointer; }

        .toast { position: fixed; top: 20px; left: 50%; transform: translateX(-50%) translateY(-100px); background: var(--lime); color: #000; padding: 12px 24px; border-radius: 12px; font-weight: 700; z-index: 1000; transition: 0.4s; }
        .toast.show { transform: translateX(-50%) translateY(0); }

        .erro-estado { grid-column: 1/-1; text-align: center; padding: 2rem; color: var(--text-muted); font-size: .82rem; }
        .erro-estado button { margin-top: 12px; background: var(--accent); color: #000; border: none; padding: 8px 20px; border-radius: 8px; font-weight: 700; cursor: pointer; }
    </style>
</head>
<body>

